rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidBill() {
      let bill = request.resource.data;
      return bill.invoiceNumber is string &&
             bill.tableNumber is string &&
             bill.status == 'pending' &&
             bill.items is list &&
             bill.totalAmount is number &&
             bill.date == request.time;
    }

    // Settings & Content: Public read, Admin write
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /categories/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /products/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Bills: Public can create with validation, Admin full access
    match /bills/{docId} {
      allow read, update, delete: if isAuthenticated();
      allow create: if isValidBill();
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }
  }
}
